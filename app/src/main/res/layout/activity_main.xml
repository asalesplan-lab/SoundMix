                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 6 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 6"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem6"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 7 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 7"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem7"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem7"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem7"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 8 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem8"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 8"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem8"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem8"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem8"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 9 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem9"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 9"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem9"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginBottom="16dp"/>

                <!-- Preview do Mix -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👂 Veja como está ficando o mix:"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btnPreviewMix"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="👂 Ouvir Mix"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/progressMix"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvMixStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#1DB954"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="▶️ PLAY"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:visibility="gone"
                    android:layout_marginBottom="4dp"/>

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="#BB86FC"
                    android:thumbTint="#BB86FC"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnDownload"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="💾 Salvar Mix"
                    android:backgroundTint="#03DAC6"
                    android:textColor="#000000"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== ABA VIDEOMIX ===== -->
    <ScrollView
        android:id="@+id/scrollVideoMix"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎬 VideoMix"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSelectBacking"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎵 Selecionar Backing Track"
                android:backgroundTint="#1DB954"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvBackingName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma backing track selecionada"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔊 Volume da Backing Track"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekBackingVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="80"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎤 Entrada de Áudio"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroupAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <RadioButton
                    android:id="@+id/radioMicAndroid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎤 Microfone do Aparelho"
                    android:textColor="#FFFFFF"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/radioMicBT"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎧 Microfone Bluetooth"
                    android:textColor="#FFFFFF"/>
                <RadioButton
                    android:id="@+id/radioMicWired"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔌 Entrada por Fio (P2/USB)"
                    android:textColor="#FFFFFF"/>
                <RadioButton
                    android:id="@+id/radioMicOTG"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎛️ Dispositivo OTG"
                    android:textColor="#FFFFFF"/>
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎧 Offset de Monitoramento"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-2500ms ◀──────────── 0 ────────────▶ +2500ms"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekLatency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="5000"
                android:progress="2500"
                android:progressTint="#BB86FC"
                android:thumbTint="#BB86FC"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 ms"
                android:textColor="#BB86FC"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <!-- Confirmador visual do offset aplicado -->
            <TextView
                android:id="@+id/tvOffsetConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1DB954"
                android:gravity="center"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnLatencyTest"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔬 Teste Diferencial de Latência"
                android:backgroundTint="#7B1FA2"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLatencyTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎧 Monitoramento"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchMonitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monitoramento em tempo real"
                android:textColor="#FFFFFF"
                android:checked="true"
                android:layout_marginBottom="16dp"/>

            <androidx.camera.view.PreviewView
                android:id="@+id/cameraPreview"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnFlipCamera"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔄 Trocar Câmera"
                android:backgroundTint="#455A64"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⏺️ INICIAR GRAVAÇÃO"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvRecordStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1DB954"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnExportVideo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎬 EXPORTAR VÍDEO"
                android:backgroundTint="#03DAC6"
                android:textColor="#000000"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
