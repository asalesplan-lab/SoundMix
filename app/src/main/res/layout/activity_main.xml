                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem3"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 4"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem4"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 5 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 5"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem5"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
