<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#1E1E1E"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#BB86FC"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- ===== ABA STEM SEPARATOR ===== -->
    <ScrollView
        android:id="@+id/scrollStemSeparator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎛️ SoundMix"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Botão selecionar música -->
            <Button
                android:id="@+id/btnSelectAudio"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📂 Selecionar Música"
                android:backgroundTint="#1DB954"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhum arquivo selecionado"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Botão separar -->
            <Button
                android:id="@+id/btnSeparate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⚡ Separar Stems"
                android:backgroundTint="#BB86FC"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"/>

            <!-- Progress + Status -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1DB954"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- ===== PAINEL DE STEMS (aparece após separação) ===== -->
            <LinearLayout
                android:id="@+id/panelStems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎚️ Ouça e escolha as faixas:"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- VOCALS -->
                <LinearLayout
                    android:id="@+id/rowVocals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbVocals"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎤 Vocals"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayVocals"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- DRUMS -->
                <LinearLayout
                    android:id="@+id/rowDrums"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbDrums"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🥁 Drums"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayDrums"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- BASS -->
                <LinearLayout
                    android:id="@+id/rowBass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbBass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎸 Bass"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayBass"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- PIANO -->
                <LinearLayout
                    android:id="@+id/rowPiano"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbPiano"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎹 Piano"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayPiano"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- GUITAR RHYTHM -->
                <LinearLayout
                    android:id="@+id/rowGuitarRhythm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbGuitarRhythm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎸 Guitar Rhythm"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayGuitarRhythm"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- GUITAR LEAD -->
                <LinearLayout
                    android:id="@+id/rowGuitarLead"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbGuitarLead"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎸 Guitar Lead (Solo)"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayGuitarLead"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- SYNTH -->
                <LinearLayout
                    android:id="@+id/rowSynth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbSynth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎛️ Synth/Pad"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlaySynth"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- STRINGS -->
                <LinearLayout
                    android:id="@+id/rowStrings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <CheckBox
                        android:id="@+id/cbStrings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎻 Strings"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayStrings"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- RESIDUAL -->
                <LinearLayout
                    android:id="@+id/rowResidual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="16dp">

                    <CheckBox
                        android:id="@+id/cbResidual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#BB86FC"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎵 Residual"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>

                    <Button
                        android:id="@+id/btnPlayResidual"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>
                </LinearLayout>

                <!-- SeekBar do stem em preview -->
                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <!-- Botão Salvar Mix -->
                <Button
                    android:id="@+id/btnDownload"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="💾 Salvar Mix"
                    android:backgroundTint="#03DAC6"
                    android:textColor="#000000"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>
            <!-- fim panelStems -->

        </LinearLayout>
    </ScrollView>

    <!-- ===== ABA VIDEOMIX ===== -->
    <ScrollView
        android:id="@+id/scrollVideoMix"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎬 VideoMix"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSelectBacking"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎵 Selecionar Backing Track"
                android:backgroundTint="#1DB954"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvBackingName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma backing track selecionada"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔊 Volume da Backing Track"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekBackingVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="80"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎤 Entrada de Áudio"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroupAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <RadioButton
                    android:id="@+id/radioMicAndroid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎤 Microfone do Aparelho"
                    android:textColor="#FFFFFF"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/radioMicBT"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎧 Microfone Bluetooth"
                    android:textColor="#FFFFFF"/>
                <RadioButton
                    android:id="@+id/radioMicWired"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔌 Entrada por Fio (P2/USB)"
                    android:textColor="#FFFFFF"/>
                <RadioButton
                    android:id="@+id/radioMicOTG"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎛️ Dispositivo OTG"
                    android:textColor="#FFFFFF"/>
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏱️ Latência Bluetooth (ms)"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekLatency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="5000"
                android:progress="0"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 ms"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnLatencyTest"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔬 Teste Diferencial de Latência"
                android:backgroundTint="#7B1FA2"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLatencyTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎧 Monitoramento"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchMonitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monitoramento em tempo real"
                android:textColor="#FFFFFF"
                android:checked="true"
                android:layout_marginBottom="16dp"/>

            <androidx.camera.view.PreviewView
                android:id="@+id/cameraPreview"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnFlipCamera"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔄 Trocar Câmera"
                android:backgroundTint="#455A64"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⏺️ INICIAR GRAVAÇÃO"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvRecordStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1DB954"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnExportVideo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎬 EXPORTAR VÍDEO"
                android:backgroundTint="#03DAC6"
                android:textColor="#000000"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
