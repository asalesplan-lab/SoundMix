<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#1E1E1E"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#BB86FC"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- ===== ABA STEM SEPARATOR ===== -->
    <ScrollView
        android:id="@+id/scrollStemSeparator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎛️ SoundMix"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSelectAudio"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📂 Selecionar Música"
                android:backgroundTint="#1DB954"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhum arquivo selecionado"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSeparate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⚡ Separar Stems"
                android:backgroundTint="#BB86FC"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1DB954"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- ===== PAINEL DE STEMS ===== -->
            <LinearLayout
                android:id="@+id/panelStems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎚️ Ouça, nomeie e escolha as faixas:"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- STEM 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stem 1"
                            android:textColor="#BB86FC"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                        <Button
                            android:id="@+id/btnPlayStem1"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekStem1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:progressTint="#FF9800"
                        android:thumbTint="#FF9800"/>
                    <EditText
                        android:id="@+id/etNameStem1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nome desta faixa (ex: Vocals, Guitarra...)"
                        android:textColorHint="#666666"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#444444"
                        android:layout_marginTop="6dp"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- STEM 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <CheckBox
                            android:id="@+id/cbStem2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#BB86FC"/>
